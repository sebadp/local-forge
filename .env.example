# === WhatsApp Cloud API ===
WHATSAPP_ACCESS_TOKEN=your_access_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
WHATSAPP_VERIFY_TOKEN=your_verify_token_here
WHATSAPP_APP_SECRET=your_app_secret_here

# Comma-separated list of phone numbers allowed to interact (with country code, no +)
ALLOWED_PHONE_NUMBERS=5491112345678

# === Ollama ===
OLLAMA_BASE_URL=http://localhost:11435
OLLAMA_MODEL=qwen3.5:9b
SYSTEM_PROMPT=You are a helpful personal assistant on WhatsApp. Be friendly. Answer in the same language the user writes in. Adapt your response length to the user's request — be brief for simple questions, detailed when asked for long or thorough answers.
CONVERSATION_MAX_MESSAGES=20

# === Database ===
DATABASE_PATH=data/localforge.db
SUMMARY_THRESHOLD=40

# === ngrok ===
NGROK_AUTHTOKEN=your_ngrok_authtoken_here
NGROK_DOMAIN=your-domain.ngrok-free.app

# === Logging ===
LOG_LEVEL=INFO
LOG_JSON=true

# === Rate Limiting ===
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW=60

# === Audio (Whisper) ===
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# === Vision ===
VISION_MODEL=llava:7b

# === Skills & Tools ===
# SKILLS_DIR=skills
# MCP_CONFIG_PATH=data/mcp_servers.json
# MAX_TOOLS_PER_CALL=8

# === Memory ===
# MEMORY_DIR=data/memory
# DAILY_LOG_DAYS=2
# MEMORY_FLUSH_ENABLED=true
# MEMORY_FILE_WATCH_ENABLED=true

# === Embeddings & Semantic Search ===
# EMBEDDING_MODEL=nomic-embed-text
# EMBEDDING_DIMENSIONS=768
# SEMANTIC_SEARCH_ENABLED=true
# SEMANTIC_SEARCH_TOP_K=10
# MEMORY_SIMILARITY_THRESHOLD=1.0

# === Context ===
# HISTORY_VERBATIM_COUNT=8
# COMPACTION_THRESHOLD=20000

# === User Profiles ===
# ONBOARDING_ENABLED=true
# PROFILE_DISCOVERY_INTERVAL=10

# === Guardrails ===
GUARDRAILS_ENABLED=true
GUARDRAILS_LANGUAGE_CHECK=true
GUARDRAILS_PII_CHECK=true
GUARDRAILS_LLM_CHECKS=false
# GUARDRAILS_DEFAULT_LANGUAGE=es
# GUARDRAILS_LLM_TIMEOUT=3.0

# === Tracing (Langfuse) ===
TRACING_ENABLED=true
TRACING_SAMPLE_RATE=1.0
TRACE_RETENTION_DAYS=90
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000

# === Evaluation & Prompts ===
EVAL_AUTO_CURATE=true
PROMPT_VERSIONING_ENABLED=true
# METRICS_PERCENTILES_ENABLED=true

# === Ontology & Knowledge Graph ===
ONTOLOGY_ENABLED=true

# === Data Provenance ===
PROVENANCE_ENABLED=true

# === Operational Automation ===
AUTOMATION_ENABLED=false
# AUTOMATION_INTERVAL_MINUTES=15
# Phone number for admin notifications (supports tg_ prefix for Telegram)
# AUTOMATION_ADMIN_PHONE=

# === Agent Mode ===
# Enable write tools (write_source_file, apply_patch) for the agent.
# OFF by default for safety — enable only in trusted environments.
AGENT_WRITE_ENABLED=false
AGENT_MAX_ITERATIONS=15
AGENT_SESSION_TIMEOUT=300
# AGENT_SHELL_ALLOWLIST=pytest,ruff,mypy,make,npm,git,cat,head,tail,wc,ls,find,grep,echo,python,node

# === GitHub Integration (for agent PR creation) ===
# GITHUB_TOKEN=
# GITHUB_REPO=owner/repo

# === Security ===
# HMAC-SHA256 key for tamper-evident audit trail. Generate with: openssl rand -hex 32
# AUDIT_HMAC_KEY=

# === Multi-Project Workspace ===
# Base directory for multi-project workspace (empty = single project)
# PROJECTS_ROOT=

# ─────────────────────────────────────────
# Telegram (opcional — desactivado por defecto)
# ─────────────────────────────────────────
TELEGRAM_ENABLED=false
# Obtener de @BotFather en Telegram (formato: 123456:ABC-... sin el prefijo "bot")
TELEGRAM_BOT_TOKEN=
# String random 1-256 chars — generar con: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=
# IDs de chat permitidos (comma-separated). Vacío = todos permitidos. Ej: 123456789,987654321
ALLOWED_TELEGRAM_CHAT_IDS=
# Si se setea, auto-registra el webhook en startup (solo la URL base, sin el path)
TELEGRAM_WEBHOOK_URL=
